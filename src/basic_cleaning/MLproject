name: basic_cleaning
conda_env: conda.yml

entry_points:
  main:
    parameters:

      input_artifact:
        description: "Name of the input artifact to download from W&B"
        type: str

      output_artifact:
        description: "Name of the output artifact to create in W&B"
        type: str

      output_type:
        description: "Type of the output artifact (e.g., clean_sample)"
        type: str

      output_description:
        description: "A description of the data cleaning performed"
        type: str

      min_price:
        description: "Minimum price to filter outliers"
        type: float

      max_price:
        description: "Maximum price to filter outliers"
        type: float


    command: >-
        python run.py  --input_artifact {input_artifact}  --output_artifact {output_artifact}  --output_type {output_type}  --output_description {output_description}  --min_price {min_price}  --max_price {max_price}